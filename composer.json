{
    "name": "mxnwire/laravel-request-id",
    "description": "Propagate request, session and correlation IDs across requests, responses and log records",
    "version": "1.2.0",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0",
        "illuminate/http": "^8.0|^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mxnwire\\RequestId\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mxnwire\\RequestId\\RequestIdServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "orchestra/testbench": "^8.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Mxnwire\\RequestId\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
